# 复制为 .env 后填写运行时密钥；未配置真实 Provider 时不会启动任务
YUWANG_DATABASE_PATH=data/yuwang.db
YUWANG_ARTIFACT_ROOT=data/artifacts
YUWANG_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
YUWANG_ADMIN_TOKEN=<generate-a-high-entropy-admin-token>
YUWANG_MASTER_KEY=<generate-a-fernet-key>
YUWANG_ALLOW_INSECURE_LOCAL_PROVIDER=false

# 生成主密钥：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Provider API Key 通过设置中心录入，只以认证加密形式保存。
