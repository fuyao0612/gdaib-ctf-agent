# 复制为 .env 后填写运行时密钥。Windows 用户也可运行 scripts/first-setup.ps1 自动生成。
# 不要提交 .env，不要把下列两个敏感值发到聊天、截图或日志中。
YUWANG_DATABASE_PATH=data/yuwang.db
YUWANG_ARTIFACT_ROOT=data/artifacts
# Docker Web 使用 8080；本地开发脚本还会自动允许 Vite 的 5173。
YUWANG_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
YUWANG_ADMIN_TOKEN=<generate-a-high-entropy-admin-token>
YUWANG_MASTER_KEY=<generate-a-fernet-key>
YUWANG_ALLOW_INSECURE_LOCAL_PROVIDER=false
YUWANG_COOKIE_SECURE=false
YUWANG_WEB_PORT=8080
YUWANG_DATA_PATH=./data
YUWANG_API_CPUS=1.0
YUWANG_API_MEMORY=768M
YUWANG_WEB_CPUS=0.5
YUWANG_WEB_MEMORY=192M

# YUWANG_DATABASE_PATH / YUWANG_ARTIFACT_ROOT 用于直接运行 API。
# scripts/start.ps1 -Development 会覆盖为 data/development 下的隔离目录，避免与 Docker 争用 SQLite。
# 生成主密钥：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Provider API Key 不写在本文件中；请通过设置中心录入，系统只保存认证加密后的密文。
