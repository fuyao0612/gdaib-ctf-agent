FROM python:3.11-slim AS runtime
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /sandbox
RUN pip install --no-cache-dir "fastapi==0.133.1" "uvicorn[standard]==0.41.0" "pydantic==2.13.4" \
    && addgroup --system --gid 10002 sandbox \
    && adduser --system --uid 10002 --ingroup sandbox sandbox \
    && mkdir -p /work \
    && chown sandbox:sandbox /work
COPY tool_sandbox ./tool_sandbox
USER sandbox
CMD ["uvicorn", "tool_sandbox.app:app", "--host", "0.0.0.0", "--port", "8081"]
